# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# PostgreSQL Configuration (Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yculture_db
DB_USER=yculture_user
DB_PASSWORD=your_password_here
DB_SSL=false

# Redis Configuration (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d

# Socket.io Configuration
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# Game Configuration
GAME_SESSION_TTL=7200
PLAYER_ONLINE_TTL=60
MAX_PLAYERS_PER_GAME=20
DEFAULT_QUESTIONS_PER_GAME=10
DEFAULT_TIME_PER_QUESTION=30

# Cleanup Configuration
CLEANUP_INTERVAL=86400000
GAME_RETENTION_HOURS=24
ANONYMOUS_USER_RETENTION_DAYS=7

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log
